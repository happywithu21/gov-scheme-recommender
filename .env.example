# .env.example
# ------------
# Template for environment variables. Ensure real keys are not checked into Git.

# Application Settings
ENVIRONMENT=development
SECRET_KEY=replace_this_with_a_strong_secret_key
API_V1_STR=/api/v1

# Database Configuration (PostgreSQL)
DB_HOST=db
DB_PORT=5432
DB_USER=scheme_user
DB_PASSWORD=scheme_password
DB_NAME=gov_schemes

# 3rd Party Integrations
# e.g., data.gov.in API Key
# DATA_GOV_API_KEY=your_key_here

DATA_GOV_API_KEY=your_data_gov_in_api_key_here
DATA_GOV_SCHEME_RESOURCE_ID=dataset_resource_id_here
