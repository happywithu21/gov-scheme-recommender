# ─────────────────────────────────────────────────────────────────────────────
# YojanaMitra  –  Environment Configuration Template
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Application
ENVIRONMENT=development
SECRET_KEY=replace_this_with_a_long_random_secret_key
API_V1_STR=/api/v1

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
DATABASE_URL=postgresql://scheme_user:scheme_password@localhost:5432/gov_schemes

# Individual fields (used by docker-compose & database.py)
DB_HOST=localhost
DB_PORT=5432
DB_USER=scheme_user
DB_PASSWORD=scheme_password
DB_NAME=gov_schemes

# ─── External APIs ────────────────────────────────────────────────────────────
# Get your free API key from https://data.gov.in/
API_KEY=your_data_gov_in_api_key_here
DATA_GOV_SCHEME_RESOURCE_ID=dataset_resource_id_here

# ─── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── Production Overrides (fill these when deploying) ─────────────────────────
# DB_HOST=your-production-db-host
# FRONTEND_URL=https://yojanamitra.in
